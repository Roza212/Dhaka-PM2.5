# Environment Variables - Example Configuration
# DO NOT ADD ACTUAL SECRETS TO THIS FILE

# Application Settings
APP_ENV=development
APP_PORT=8000
DEBUG=True

# Authentication
# Generate a strong secret key for JWT (e.g., using `openssl rand -hex 32`)
JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External APIs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
OPENAQ_API_KEY=your_openaq_api_key_here
WEATHER_API_KEY=your_weather_api_key_here

# Database Configuration (if applicable)
DATABASE_URL=postgresql://user:password@localhost:5432/dhaka_pm25

# MLOps Config
MLFLOW_TRACKING_URI=http://localhost:5000
